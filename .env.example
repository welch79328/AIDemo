# ================================
# 環境變數範例文件
# 使用方式: 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# ================================

# ================================
# 通用設定
# ================================
ENV=development  # development | staging | production
DEBUG=true
TZ=Asia/Taipei

# ================================
# 資料庫設定
# ================================
DB_PASSWORD=postgres123
# 注意：Docker 容器內部使用 postgres:5432，外部訪問使用 localhost:5434
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@postgres:5432/sales_performance

# 資料庫連線池設定
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false  # 是否顯示 SQL 查詢（開發時可開啟）

# ================================
# Redis 設定（可選，用於快取）
# ================================
REDIS_URL=redis://redis:6379/0

# ================================
# CORS 設定
# ================================
# 使用 Nginx 反向代理時，Frontend 和 Backend 在同一 origin，CORS 設定可簡化
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8087,http://localhost:8001

# ================================
# 前端設定（Vue）
# ================================
# 使用 Nginx 反向代理時，Frontend 使用相對路徑 /api 調用 Backend
# 該設定在 docker-compose.yml 中已配置，通常不需要在 .env 中覆蓋
VITE_API_BASE_URL=http://localhost:8001
VITE_APP_TITLE=業務行動成效評估系統
VITE_APP_VERSION=1.0.0

# ================================
# Email 設定（選用，用於通知）
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@example.com

# ================================
# 檔案上傳設定
# ================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ================================
# 日誌設定
# ================================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=/app/logs/app.log

# ================================
# 監控設定（選用）
# ================================
SENTRY_DSN=  # Sentry 錯誤追蹤 DSN
SENTRY_ENVIRONMENT=development

# ================================
# 第三方整合（選用）
# ================================
# OpenAI API（用於對談分析）
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini  # gpt-4o-mini | gpt-4o | gpt-3.5-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# LINE OA API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Analytics
GA_TRACKING_ID=

# ================================
# 開發工具設定
# ================================
# Adminer 資料庫管理
ADMINER_PORT=8080
ADMINER_DESIGN=dracula

# ================================
# 生產環境專用設定
# ================================
# SSL/TLS 憑證路徑
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# CDN 設定
CDN_URL=

# 備份設定
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨 2 點
BACKUP_RETENTION_DAYS=30
